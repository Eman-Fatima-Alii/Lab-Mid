{
  "name": "cafeteria-management",
  "type": "module",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server/run-dev.mjs",
    "dev:client": "vite",
    "dev:server": "node server/verification-server.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test:run": "vitest run",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.cafeteria.management",
    "productName": "Cafeteria Management System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
